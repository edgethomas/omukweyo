# Production Environment Variables for Omukweyo
# Copy this file and configure for your production server

# Node Environment
NODE_ENV=production

# Backend API Configuration
PORT=4000
WEB_ORIGIN=https://omukweyo.com
DATABASE_URL="mysql://username:password@host:3306/omukweyo"
UPLOAD_BASE_URL=https://omukweyo.com/uploads

# Optional: Custom paths
# UPLOAD_DIR=/var/www/uploads
# WEB_DIST_DIR=/var/www/apps/web/dist

# Frontend Configuration (must match your domain)
VITE_API_URL=https://omukweyo.com
VITE_WS_URL=https://omukweyo.com

# Optional: External Services (for future production features)
# GOOGLE_PLACES_API_KEY=your_google_places_key
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+264...
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@omukweyo.com
# SMTP_PASSWORD=your_email_password

# Security (for JWT in future versions)
# JWT_SECRET=generate-a-random-secure-string-here
